---
import SectionHeader from './SectionHeader.astro';
import { highlights } from '../data/highlights';
const items = [...highlights].sort((a, b) => +new Date(b.date) - +new Date(a.date));
const featured = items[0];
const rest = items.slice(1);
---

<section id="highlights" class="mx-auto max-w-[1400px] px-5 py-28 sm:px-8 lg:px-12">
  <SectionHeader
    index="05"
    eyebrow="Highlights & Press"
    title="In the spotlight"
    subtitle="Coverage of my work and achievements, published by Universitas Gadjah Mada."
  />

  <div class="grid gap-10 lg:grid-cols-12">
    <!-- Featured -->
    <a href={`/highlights/${featured.slug}`} class="border-grad group reveal relative overflow-hidden rounded-2xl lg:col-span-6">
      <div class="aspect-[16/11] overflow-hidden">
        {featured.coverImage ? (
          <img src={featured.coverImage} alt={featured.title} loading="lazy" class="h-full w-full object-cover opacity-70 transition-all duration-500 group-hover:opacity-90 group-hover:scale-105" />
        ) : (
          <div class="h-full w-full bg-gradient-to-br from-emerald-700/40 to-purple-800/40"></div>
        )}
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/40 to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 p-7">
        <span class="eyebrow">{featured.category} · {featured.dateDisplay}</span>
        <h3 class="mt-2 font-display text-2xl font-bold text-gray-100 sm:text-3xl">{featured.title}</h3>
        <p class="mt-2 line-clamp-2 max-w-xl text-sm text-gray-300">{featured.description}</p>
      </div>
    </a>

    <!-- List -->
    <div class="lg:col-span-6">
      {rest.map((h) => (
        <a href={`/highlights/${h.slug}`} class="work-row group flex items-center gap-5 py-5">
          <div class="min-w-0 flex-1">
            <span class="eyebrow">{h.category} · {h.dateDisplay}</span>
            <h3 class="work-name mt-1 font-display text-lg font-semibold text-gray-100 sm:text-xl">{h.title}</h3>
          </div>
          <svg class="h-5 w-5 flex-shrink-0 text-gray-500 transition-transform duration-300 group-hover:translate-x-1 group-hover:text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
        </a>
      ))}
      <a href="/highlights" class="group mt-6 inline-flex items-center gap-2 font-display text-gray-200 hover:text-emerald-400">All highlights <span class="transition-transform group-hover:translate-x-1">→</span></a>
    </div>
  </div>
</section>
