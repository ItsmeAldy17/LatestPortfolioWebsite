---
import { Image } from 'astro:assets';
import { site } from '../config/site';
import profileImg from '../assets/Aldy.jpg';
import achievements from '../data/achievements.json';
import projects from '../data/project_details.json';

const stats = [
  { value: `${achievements.length}`, label: 'Awards' },
  { value: `${projects.length}`, label: 'Projects' },
  { value: '3+', label: 'Years' },
  { value: '5', label: 'Features' },
];
---

<section id="hero" class="relative flex min-h-screen items-center overflow-hidden">
  <div class="aurora"></div>

  <div class="container-lux relative z-10 grid w-full items-center gap-10 pt-28 pb-16 lg:grid-cols-[1.15fr_0.85fr] lg:gap-16 lg:pt-24">
    <!-- Left: content -->
    <div>
      <div class="reveal mb-6 inline-flex items-center gap-3 rounded-full border border-blue-400/30 bg-blue-500/5 px-4 py-1.5">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-blue-400"></span>
        </span>
        <span class="text-sm font-medium text-gray-300">{site.jobTitle} · {site.location.city}</span>
      </div>

      <h1 class="reveal font-display text-5xl font-extrabold leading-[0.95] text-white sm:text-6xl lg:text-7xl">
        Aldy<br /><span class="gradient-text">Ardiansyah</span>
      </h1>

      <p class="reveal mt-6 max-w-xl text-lg leading-relaxed text-gray-300">
        I build impactful, AI-powered systems — specializing in
        <span class="text-neon">computer vision</span>,
        <span class="text-neon">deep learning</span>, and
        <span class="text-neon">MLOps</span>. Turning research into products that ship.
      </p>

      <div class="reveal mt-8 flex flex-wrap items-center gap-4">
        <a href="#selected-work" class="magnetic glow rounded-full bg-gradient-to-r from-emerald-500 to-blue-500 px-7 py-3.5 font-semibold text-white">
          View Projects
        </a>
        <a href="#contact" class="magnetic rounded-full border border-white/15 px-7 py-3.5 font-medium text-gray-200 transition-colors hover:border-blue-400/60 hover:text-blue-300">
          Get in touch
        </a>
        <div class="flex gap-4 pl-1">
          <a href={site.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-gray-400 transition-colors hover:text-blue-300">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.42.36.79 1.07.79 2.16v3.2c0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z"/></svg>
          </a>
          <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-gray-400 transition-colors hover:text-blue-300">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
        </div>
      </div>

      <dl class="reveal mt-12 grid max-w-lg grid-cols-4 gap-4 border-t border-white/8 pt-6">
        {stats.map((s) => (
          <div>
            <dt class="font-display text-2xl font-bold text-white sm:text-3xl">{s.value}</dt>
            <dd class="mt-0.5 text-xs text-gray-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>

    <!-- Right: portrait -->
    <div class="reveal reveal-scale flex justify-center lg:justify-end">
      <div class="conic-ring relative w-full max-w-sm overflow-hidden rounded-3xl">
        <Image
          src={profileImg}
          alt={`${site.name} — ${site.jobTitle}`}
          width={620}
          height={760}
          widths={[320, 480, 620]}
          sizes="(min-width: 1024px) 384px, 320px"
          loading="eager"
          fetchpriority="high"
          class="aspect-[4/5] w-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-gray-950/70 via-transparent to-transparent"></div>
        <div class="beam"></div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-gray-600">
    <svg class="h-6 w-6 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
  </div>
</section>
