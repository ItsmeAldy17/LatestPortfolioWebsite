---
import { site, navLinks } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-white/8 px-5 py-12 sm:px-8 lg:px-12">
  <div class="mx-auto max-w-[1400px]">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <a href="/#hero" class="flex items-center gap-3">
        <span class="flex h-9 w-9 items-center justify-center rounded-full border border-emerald-500/40 font-display text-xs font-bold text-emerald-400">AA</span>
        <span class="font-display text-sm text-gray-300">Aldy Ardiansyah</span>
      </a>

      <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2" aria-label="Footer">
        {navLinks.map((l) => (
          <a href={l.href} class="text-sm text-gray-500 transition-colors hover:text-emerald-400">{l.name}</a>
        ))}
      </nav>

      <div class="flex gap-6">
        <a href={site.social.github} target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 hover:text-emerald-400">GitHub</a>
        <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 hover:text-emerald-400">LinkedIn</a>
      </div>
    </div>

    <div class="mt-8 flex flex-col items-center justify-between gap-2 border-t border-white/5 pt-6 text-xs text-gray-600 sm:flex-row">
      <span>© {year} {site.name}. {site.location.city}, {site.location.country}.</span>
      <span>Built with less sleep and more coffee.</span>
    </div>
  </div>
</footer>
