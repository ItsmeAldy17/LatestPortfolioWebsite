---
const row1 = ['Python', 'TensorFlow', 'PyTorch', 'Scikit-learn', 'OpenCV', 'NumPy', 'Pandas', 'Keras'];
const row2 = ['Docker', 'Git', 'Linux', 'Node.js', 'Flask', 'FastAPI', 'MySQL', 'MongoDB', 'PostgresSQL', 'Socket.io'];
const iconFix: Record<string, string> = { TensorFlow: 'Tensorflow', PyTorch: 'Pytorch' };
const iconOf = (n: string) => `/icons/${iconFix[n] ?? n}.png`;
const all1 = [...row1, ...row1];
const all2 = [...row2, ...row2];
---

<section id="tech-stack" class="relative overflow-hidden py-16">
  <p class="container-lux eyebrow mb-8 text-center">Tools & Technologies I work with</p>

  <div class="marquee mb-4">
    <div class="marquee-track marquee-l">
      {all1.map((n) => (
        <div class="flex flex-shrink-0 items-center gap-3 rounded-full border border-blue-400/15 bg-blue-500/5 px-5 py-3 transition-colors hover:border-blue-400/50">
          <img src={iconOf(n)} alt={n} width="26" height="26" loading="lazy" class="h-6 w-6 object-contain" />
          <span class="whitespace-nowrap font-display font-medium text-gray-200">{n}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="marquee">
    <div class="marquee-track marquee-r">
      {all2.map((n) => (
        <div class="flex flex-shrink-0 items-center gap-3 rounded-full border border-blue-400/15 bg-blue-500/5 px-5 py-3 transition-colors hover:border-blue-400/50">
          <img src={iconOf(n)} alt={n} width="26" height="26" loading="lazy" class="h-6 w-6 object-contain" />
          <span class="whitespace-nowrap font-display font-medium text-gray-200">{n}</span>
        </div>
      ))}
    </div>
  </div>
</section>
