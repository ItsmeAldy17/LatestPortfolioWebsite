---
import { navLinks, site } from '../config/site';
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="mx-auto flex h-20 max-w-[1400px] items-center justify-between px-5 sm:px-8 lg:px-12" aria-label="Primary">
    <!-- Monogram -->
    <a href="/#hero" class="group flex items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center rounded-full border border-emerald-500/40 font-display text-sm font-bold text-emerald-400 transition-colors group-hover:border-emerald-400 group-hover:bg-emerald-500/10">AA</span>
      <span class="hidden text-sm font-medium tracking-wide text-gray-300 sm:block">Aldy Ardiansyah</span>
    </a>

    <!-- Center nav -->
    <div class="hidden items-center gap-8 lg:flex">
      {navLinks.map((l, i) => (
        <a href={l.href} class="group flex items-baseline gap-1.5 text-sm text-gray-400 transition-colors hover:text-gray-100">
          <span class="text-[0.6rem] text-emerald-500/70">{String(i + 1).padStart(2, '0')}</span>
          <span class="relative">
            {l.name}
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-emerald-400 transition-all duration-300 group-hover:w-full"></span>
          </span>
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <a
        href="#contact"
        class="hidden rounded-full border border-emerald-500/50 px-5 py-2 text-sm font-medium text-emerald-400 transition-all hover:bg-emerald-500 hover:text-gray-900 sm:inline-block"
      >
        Let's connect
      </a>
      <button id="menu-toggle" class="text-gray-200 hover:text-emerald-400 lg:hidden" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>
      </button>
    </div>
  </nav>
  <div class="hairline opacity-0 transition-opacity duration-500" id="nav-hairline"></div>

  <div id="mobile-menu" class="overflow-hidden transition-[max-height] duration-300 ease-in-out lg:hidden" style="max-height:0">
    <div class="border-t border-white/5 bg-gray-950/95 px-6 py-6 backdrop-blur-xl">
      {navLinks.map((l, i) => (
        <a href={l.href} class="flex items-baseline gap-3 py-2.5 text-lg text-gray-300 hover:text-blue-300">
          <span class="text-xs text-blue-400/70">{String(i + 1).padStart(2, '0')}</span>
          {l.name}
        </a>
      ))}
      <a href="#contact" class="mt-4 inline-block rounded-full border border-blue-400/50 px-5 py-2 text-sm font-medium text-blue-300">Let's connect</a>
    </div>
  </div>
</header>
