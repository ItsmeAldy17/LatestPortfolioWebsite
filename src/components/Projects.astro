---
import SectionHeader from './SectionHeader.astro';
import projects from '../data/project_details.json';
const featured = projects.slice(0, 6);
const clip = (s: string, n = 120) => (s.length > n ? s.slice(0, n).trimEnd() + '…' : s);
---

<section id="selected-work" class="container-lux py-24">
  <SectionHeader
    index="02"
    eyebrow="Projects"
    title="Things I've built"
    subtitle="Machine learning, computer vision, and full-stack projects — from research to shipped products."
  />

  <div class="reveal">
    {featured.map((p, i) => (
      <a href={`/project/${p.id}`} class="work-row group grid grid-cols-[auto_1fr_auto] items-center gap-x-5 gap-y-2 py-7 sm:gap-x-8">
        <span class="font-display text-sm text-blue-400/70">{String(i + 1).padStart(2, '0')}</span>
        <div class="min-w-0">
          <h3 class="work-name font-display text-2xl font-semibold text-white sm:text-3xl">{p.name}</h3>
          <p class="mt-1 max-w-2xl text-sm leading-relaxed text-gray-400">{clip(p.overview)}</p>
          <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
            <span class="text-neon">{p.role}</span>
            <span class="h-1 w-1 rounded-full bg-gray-600"></span>
            <span>{p.category}</span>
            <span class="h-1 w-1 rounded-full bg-gray-600"></span>
            <span>{p.timeline}</span>
          </div>
        </div>
        <svg class="h-5 w-5 flex-shrink-0 self-start text-gray-500 transition-all duration-300 group-hover:translate-x-1 group-hover:text-blue-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
        <div class="work-thumb">
          <img src={p.card_image_src} alt={p.name} loading="lazy" class="h-full w-full object-cover" />
        </div>
      </a>
    ))}
  </div>

  <a href="/all-projects" class="group mt-12 inline-flex items-center gap-2 font-display text-lg text-gray-200 hover:text-blue-300">
    View all {projects.length} projects <span class="transition-transform group-hover:translate-x-1">→</span>
  </a>
</section>
