---
import SectionHeader from './SectionHeader.astro';
import achievements from '../data/achievements.json';
const items = achievements.slice(0, 6);
const norm = (p: string) => (p.startsWith('/') ? p : `/${p}`);
---

<section id="achievements" class="container-lux py-24">
  <SectionHeader
    index="04"
    eyebrow="Awards & Honors"
    title="Recognition"
    subtitle="National and international competitions, programs, and honors."
  />

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((a) => (
      <article class="glow-card group reveal flex flex-col">
        <div class="relative flex aspect-[4/3] items-center justify-center overflow-hidden bg-gray-900 p-3">
          <img src={norm(a.image)} alt={`${a.name} — ${a.organization}`} loading="lazy" class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-[1.03]" />
          <span class="absolute left-3 top-3 rounded-full border border-blue-400/40 bg-gray-950/60 px-2.5 py-1 text-xs text-neon backdrop-blur-md">{a.category} · {a.year}</span>
        </div>
        <div class="flex flex-1 flex-col border-t border-white/8 p-5">
          <h3 class="font-display text-base font-bold leading-snug text-white">{a.name}</h3>
          <p class="mt-1 text-sm text-neon">{a.organization}</p>
          <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-gray-400">{a.description}</p>
        </div>
      </article>
    ))}
  </div>

  <a href="/all-achievements" class="group mt-10 inline-flex items-center gap-2 font-display text-lg text-gray-200 hover:text-blue-300">
    Explore all achievements &amp; certifications <span class="transition-transform group-hover:translate-x-1">→</span>
  </a>
</section>
