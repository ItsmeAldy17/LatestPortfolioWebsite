---
interface Props {
  index: string;
  eyebrow: string;
  title: string;
  subtitle?: string;
}
const { index, eyebrow, title, subtitle } = Astro.props;
---

<div class="reveal mb-12 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
  <div class="flex items-start gap-5">
    <span class="idx">{index}</span>
    <div>
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="display-md mt-2 text-gray-100">{title}</h2>
    </div>
  </div>
  {subtitle && <p class="max-w-md text-gray-400 md:text-right">{subtitle}</p>}
</div>
