---
import { site } from '../config/site';
---

<section id="contact" class="relative overflow-hidden px-5 py-36 sm:px-8 lg:px-12">
  <div class="aurora"></div>
  <div class="relative z-10 mx-auto max-w-[1400px] text-center">
    <span class="eyebrow reveal">Let's connect</span>
    <h2 class="reveal display mt-5 text-gray-100">
      Let's build something
      <span class="block gradient-text">exceptional.</span>
    </h2>
    <p class="reveal mx-auto mt-8 max-w-xl text-lg text-gray-400">
      Open to roles, collaborations, and research in machine learning and computer vision.
      My CV has the full details — let's connect.
    </p>

    <div class="reveal mt-10 flex justify-center">
      <a href={site.cvUrl} target="_blank" rel="noopener noreferrer" class="magnetic glow rounded-full bg-gradient-to-r from-emerald-500 to-blue-500 px-10 py-4 text-lg font-semibold text-white">
        View my CV
      </a>
    </div>

    <div class="reveal mt-12 flex items-center justify-center gap-8">
      <a href={site.social.github} target="_blank" rel="noopener noreferrer" class="text-sm tracking-wide text-gray-400 transition-colors hover:text-emerald-400">GitHub</a>
      <span class="h-4 w-px bg-white/15"></span>
      <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm tracking-wide text-gray-400 transition-colors hover:text-emerald-400">LinkedIn</a>
    </div>
  </div>
</section>
