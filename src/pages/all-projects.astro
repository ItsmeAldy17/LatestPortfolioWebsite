---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import projects from '../data/project_details.json';
import { breadcrumbSchema } from '../lib/schema';

const schema = [breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Projects', url: '/all-projects' }])];
---

<PageLayout title="All Projects" description="A complete portfolio of machine learning, computer vision, and software engineering projects by Aldy Ardiansyah." schema={schema}>
  <PageHeader
    eyebrow="Selected Work"
    title="All projects"
    subtitle={`${projects.length} projects across machine learning, computer vision, and full-stack engineering.`}
    crumbs={[{ name: 'Home', href: '/' }, { name: 'Projects' }]}
  />

  <div class="container-lux pb-28">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <a href={`/project/${p.id}`} class="tilt border-grad group flex flex-col overflow-hidden rounded-2xl">
          <div class="relative aspect-video overflow-hidden">
            <img src={p.card_image_src} alt={p.name} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" style={`view-transition-name: project-${p.id}`} />
            <span class="absolute right-3 top-3 rounded-full border border-emerald-500/40 bg-gray-950/60 px-2.5 py-1 text-xs text-emerald-400 backdrop-blur-sm">{p.category}</span>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h2 class="font-display text-xl font-semibold text-gray-100 transition-colors group-hover:text-neon">{p.name}</h2>
            <p class="mt-1 text-sm text-neon">{p.role}</p>
            <p class="mt-3 line-clamp-3 flex-1 text-sm leading-relaxed text-gray-400">{p.overview}</p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-gray-300 group-hover:text-emerald-400">
              View project <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <a href="/" class="group mt-16 inline-flex items-center gap-2 font-display text-gray-200 hover:text-emerald-400">
      <span class="transition-transform group-hover:-translate-x-1">←</span> Back to home
    </a>
  </div>
</PageLayout>
