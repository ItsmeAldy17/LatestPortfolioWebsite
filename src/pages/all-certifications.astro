---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import certifications from '../data/certifications.json';
import { breadcrumbSchema } from '../lib/schema';

const norm = (p: string) => (p.startsWith('/') ? p : `/${p}`);
const isLink = (v: string) => typeof v === 'string' && v.startsWith('http');
const schema = [breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Certifications', url: '/all-certifications' }])];
---

<PageLayout title="All Certifications" description="Professional certifications held by Aldy Ardiansyah in machine learning, AI, and data — from Dicoding, Microsoft Azure, and more." schema={schema}>
  <PageHeader
    eyebrow="Credentials"
    title="All certifications"
    subtitle="Verified credentials in machine learning, AI, and data."
    crumbs={[{ name: 'Home', href: '/' }, { name: 'Certifications' }]}
  />

  <div class="container-lux pb-28">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {certifications.map((c) => (
        <article class="border-grad reveal flex flex-col overflow-hidden rounded-2xl">
          <div class="flex aspect-video items-center justify-center overflow-hidden bg-gray-900 p-3">
            <img src={norm(c.image)} alt={`${c.name} — ${c.organization}`} loading="lazy" class="max-h-full max-w-full object-contain" />
          </div>
          <div class="flex flex-1 flex-col p-6">
            <div class="mb-2 flex items-center justify-between gap-2 text-xs text-gray-500">
              <span>{c.date}</span>
              <span>Valid · {c.expiryDate}</span>
            </div>
            <h2 class="font-display text-base font-semibold leading-snug text-gray-100">{c.name}</h2>
            <p class="mt-1 text-sm text-neon">{c.organization}</p>
            <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-gray-400">{c.description}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {c.skills.slice(0, 4).map((s) => (
                <span class="rounded-full border border-white/10 px-2.5 py-1 text-xs text-gray-400">{s}</span>
              ))}
            </div>
            {isLink(c.verificationUrl) && (
              <a href={c.verificationUrl} target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-emerald-400 hover:underline">Verify credential →</a>
            )}
          </div>
        </article>
      ))}
    </div>

    <a href="/" class="group mt-16 inline-flex items-center gap-2 font-display text-gray-200 hover:text-emerald-400"><span class="transition-transform group-hover:-translate-x-1">←</span> Back to home</a>
  </div>
</PageLayout>
