---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import achievements from '../data/achievements.json';
import { breadcrumbSchema } from '../lib/schema';

const norm = (p: string) => (p.startsWith('/') ? p : `/${p}`);
const schema = [breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Achievements', url: '/all-achievements' }])];
---

<PageLayout title="All Achievements" description="Awards and recognition earned by Aldy Ardiansyah across national and international AI, IoT, and innovation competitions." schema={schema}>
  <PageHeader
    eyebrow="Recognition"
    title="All achievements"
    subtitle="Awards and honors from national and international competitions and programs."
    crumbs={[{ name: 'Home', href: '/' }, { name: 'Achievements' }]}
  />

  <div class="container-lux pb-28">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {achievements.map((a) => (
        <article class="glow-card group reveal flex flex-col">
          <div class="relative flex aspect-[4/3] items-center justify-center overflow-hidden bg-gray-900 p-3">
            <img src={norm(a.image)} alt={`${a.name} — ${a.organization}`} loading="lazy" class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-[1.03]" />
            <span class="absolute left-3 top-3 rounded-full border border-blue-400/40 bg-gray-950/60 px-2.5 py-1 text-xs text-neon backdrop-blur-md">{a.category} · {a.year}</span>
          </div>
          <div class="flex flex-1 flex-col border-t border-white/8 p-5">
            <h2 class="font-display text-base font-bold leading-snug text-white">{a.name}</h2>
            <p class="mt-1 text-sm text-neon">{a.organization}</p>
            <p class="mt-2 text-sm leading-relaxed text-gray-400">{a.description}</p>
            {a.impact && <p class="mt-3 text-xs italic text-gray-500">Impact · {a.impact}</p>}
          </div>
        </article>
      ))}
    </div>

    <div class="mt-10"><a href="/all-certifications" class="group inline-flex items-center gap-2 font-display text-gray-200 hover:text-emerald-400">View all certifications <span class="transition-transform group-hover:translate-x-1">→</span></a></div>
    <a href="/" class="group mt-12 inline-flex items-center gap-2 font-display text-gray-200 hover:text-emerald-400"><span class="transition-transform group-hover:-translate-x-1">←</span> Back to home</a>
  </div>
</PageLayout>
